{
	"name": "take-home-test",
	"version": "1.0.0",
	"description": "Take home test project",
	"main": "dist/index.js",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"dev": "ts-node-dev --respawn src/index.ts",
		"test": "vitest run",
		"lint": "eslint . && prettier --check .",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"keywords": [],
	"license": "ISC",
	"devDependencies": {
		"@testcontainers/postgresql": "^10.28.0",
		"@types/express": "^5.0.0",
		"@types/node": "^22.0.0",
		"@types/pg": "^8.11.0",
		"@types/supertest": "^6.0.0",
		"drizzle-kit": "^0.28.0",
		"eslint": "^9.15.0",
		"eslint-config-prettier": "^9.1.0",
		"prettier": "^3.3.0",
		"supertest": "^7.0.0",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.15.0",
		"vitest": "^2.1.0"
	},
	"dependencies": {
		"drizzle-orm": "^0.36.0",
		"express": "^4.22.1",
		"express-rate-limit": "^8.5.2",
		"pg": "^8.13.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"zod": "^3.25.76"
	}
}
