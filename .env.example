# Server
PORT=3000

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/forms

# Scoped API keys — each opens a disjoint set of routes:
#   PROVIDER_API_KEY -> POST /ingest
#   BOT_API_KEY      -> POST /forms/ready
#   OPS_API_KEY      -> POST /forms/:id/retry, GET /forms/:id
# /health is always open. These routes fail closed: a blank key locks that
# scope out entirely (nothing can match it) rather than leaving it open, so
# all three must be set to real values before deploying.
PROVIDER_API_KEY=
BOT_API_KEY=
OPS_API_KEY=

# Requests per minute, per api key (falls back to client IP if no key)
RATE_LIMIT_PER_MINUTE=300

# Geocoder client (timeout/retry/backoff)
GEOCODER_TIMEOUT_MS=3000
GEOCODER_ATTEMPTS=3
GEOCODER_BACKOFF_MS=100

# Sweeper (recovers forms stuck in a non-terminal status)
SWEEP_INTERVAL_MS=15000
SWEEP_STALENESS_MS=60000

# Outbox worker (email delivery retry/backoff)
OUTBOX_INTERVAL_MS=5000
OUTBOX_BACKOFF_BASE_MS=1000
OUTBOX_BACKOFF_CAP_MS=300000
